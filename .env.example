# LeaveDesk environment example
#
# Local development normally works without setting anything.
# Render supplies PORT automatically; do not hardcode it there unless Render asks.

HOST=0.0.0.0
PORT=8000

# Local defaults:
DATA_DIR=data
UPLOAD_DIR=data/uploads
DB_PATH=data/leave_app.sqlite3

# Render persistent disk values:
# DATA_DIR=/var/data
# UPLOAD_DIR=/var/data/uploads
# DB_PATH=/var/data/leave_app.sqlite3
