# LeaveDesk environment example

# Cloudflare production uses bindings in wrangler.toml instead of a .env file:
# - DB: Cloudflare D1 database binding
# - ATTACHMENTS: Cloudflare R2 bucket binding
#
# No production SQLite file or local upload folder is used by the Cloudflare Worker.
#
# Optional local Python fallback settings are below only for the old local app.

HOST=0.0.0.0
PORT=8000

# Local defaults:
DATA_DIR=data
UPLOAD_DIR=data/uploads
DB_PATH=data/leave_app.sqlite3
