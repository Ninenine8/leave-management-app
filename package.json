{
  "name": "leave-management-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Workers Leave Management App for Singapore small companies",
  "scripts": {
    "build": "node --check src/worker.js && node --check src/rules.js",
    "test": "node --test",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply leave-management-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply leave-management-db --remote"
  },
  "devDependencies": {
    "wrangler": "^4.24.3"
  }
}
